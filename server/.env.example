# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Supabase PostgreSQL Connection URL)
# Replace with your actual Supabase connection string from settings
DATABASE_URL=postgresql://postgres:[password]@db.[project_id].supabase.co:5432/postgres?schema=public

# JWT Token Settings
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=7d
